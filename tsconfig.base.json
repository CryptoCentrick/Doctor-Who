{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@doctor-who/shared": [
        "packages/shared/src/index.ts"
      ],
      "@doctor-who/shared/*": [
        "packages/shared/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules"
  ]
}
