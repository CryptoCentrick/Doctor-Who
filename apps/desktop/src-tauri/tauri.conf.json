{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Doctor Who",
  "version": "0.1.0",
  "identifier": "app.doctorwho.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Doctor Who",
        "width": 1440,
        "height": 940,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
